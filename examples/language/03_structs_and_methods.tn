-- Structs carry fields and callable members. Methods use `self`.

struct Counter {
  value: Int

  bump(amount: Int): Int = {
    self.value = self.value + amount
    self.value
  }

  label(): String = "count={self.value}"
}

let counter = Counter { value = 10 }
let bumped = counter.bump(5)
print("{counter.label()}:{bumped}")
