-- Generic callables and structs keep shape information through lowering.

struct Box<T> {
  value: T
}

let id<T>(value: T): T = value
let read<T>(box: Box<T>): T = box.value

let number: Int = id(4)
let word: String = read(Box { value = "tune" })
let display: String = "{number}:{word}"
let shown: () = print(display)
