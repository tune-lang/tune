-- Import standard modules and call members through module namespaces.

import "parse"
import "text"

let parse_answer(raw: String): Result<Int, String> = {
  let cleaned: String = text.trim(raw)
  let value: Int = parse.int(cleaned)!
  Ok(value + 1)
}

let parsed_answer: Result<Int, String> = parse_answer(" 41 ")
print("std imports accepted")
